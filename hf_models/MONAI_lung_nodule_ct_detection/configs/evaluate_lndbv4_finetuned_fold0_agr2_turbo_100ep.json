    "eval_ckpt_filename": "best.pt",
    "output_dir": "/root/autodl-tmp/LNDbv4_monai_luna16_aligned/monai_finetune_fold0_agr2_turbo_100ep/eval_best",
    "validate#preprocessing": {
        "_target_": "Compose",
        "transforms": [
            {
                "_target_": "LoadImaged",
                "keys": "image"
            },
            {
                "_target_": "EnsureChannelFirstd",
                "keys": "image"
            },
            {
                "_target_": "EnsureTyped",
                "keys": [
                    "image",
                    "box"
                ]
            },
            {
                "_target_": "Lambdad",
                "keys": "box",
                "func": "$lambda x: x.reshape((-1, 6))"
            },
            {
                "_target_": "EnsureTyped",
                "keys": "label",
                "dtype": "$torch.long"
            },
            {
                "_target_": "Orientationd",
                "keys": "image",
                "axcodes": "RAS"
            },
            {
                "_target_": "ScaleIntensityRanged",
                "keys": "image",
                "a_min": -1024.0,
                "a_max": 300.0,
                "b_min": 0.0,
                "b_max": 1.0,
                "clip": true
            },
            {
                "_target_": "ConvertBoxToStandardModed",
                "box_keys": "box",
                "mode": "cccwhd"
            },
            {
                "_target_": "AffineBoxToImageCoordinated",
                "box_keys": "box",
                "box_ref_image_keys": "image",
                "affine_lps_to_ras": true
            },
            {
                "_target_": "EnsureTyped",
                "keys": [
                    "image",
                    "box"
                ]
            },
            {
                "_target_": "EnsureTyped",
                "keys": "label",
                "dtype": "$torch.long"
            },
            {
                "_target_": "ToTensord",
                "keys": [
                    "image",
                    "box",
                    "label"
                ]
            }
        ]
    }
}
